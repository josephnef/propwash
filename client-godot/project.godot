; propwash Godot 4 client (MIT) — speaks the UDP protocol to propwash-core.
; Engine.
config_version=5

[application]

config/name="propwash"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[physics]

; Baseline lockstep rate — headless/CI runs at exactly this. The client raises
; it at runtime to match the monitor (see _match_tick_rate in main.gd); it is
; deliberately NOT pinned high here, so a 60 Hz setup keeps paying what it
; always has. Interpolation is cheap and smooths the leftover mismatch (100 Hz
; physics does not divide 60 Hz refresh either), so it is on for everyone.
common/physics_ticks_per_second=100
common/physics_interpolation=true

[rendering]

; Forward+ (Vulkan/Metal). gl_compatibility presents at only ~133 fps on a
; 240 Hz macOS display even when the scene can push 750 — the OpenGL-on-Metal
; path doesn't sync to high refresh. fallback_to_opengl3 (engine default, set
; explicitly here) drops back to the compatibility renderer when the rendering
; device won't initialise, so old GPUs still run.
renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="gl_compatibility"
rendering_device/fallback_to_opengl3=true

; MSAA, deliberately NOT TAA. A 105 deg FOV camera translating and rotating fast
; is worst-case for temporal reprojection; the goggle-feed sharpening pass would
; amplify TAA ghosting into smear halos; TAA is Forward+-only so it vanishes
; under the Compatibility fallback; and it costs a frame of latency in a sim
; built around latency. Debanding is near-free and kills the sky gradient
; banding that tonemapping + glow would otherwise expose.
anti_aliasing/quality/msaa_3d=1
anti_aliasing/quality/screen_space_aa=0
anti_aliasing/quality/use_taa=false
anti_aliasing/quality/use_debanding=true

; 4096 over a 60 m cascade range beats 8192 over 120 m: same texels, half the
; distance, so better shadow resolution AND cheaper. Doubling the atlas was the
; wrong fix for the acne -- the cascade range was.
lights_and_shadows/directional_shadow/size=4096
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=2
